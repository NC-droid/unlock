# Copy this to .env and fill in your values
# DO NOT commit .env to git (it's in .gitignore)

# Server
PORT=3001
NODE_ENV=development

# Azure Database for PostgreSQL
# Found in: Azure Portal → PostgreSQL → unlock-db-server → Connection strings
DATABASE_URL=postgresql://adminuser:yourpassword@unlock-db-server.postgres.database.azure.com:5432/unlock?sslmode=require

# Azure Entra External ID (JWT Verification)
# Found in: Azure Portal → Entra External ID → App Registrations → unlock-app
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_TENANT_NAME=your-tenant-name   # e.g. "unlockapp" (without .onmicrosoft.com)

# Azure Blob Storage (for student document uploads)
# Found in: Azure Portal → Storage Accounts → unlockdocuments → Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=unlockdocuments;AccountKey=xxx;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=student-docs

# Claude API (Anthropic)
# Found at: console.anthropic.com → API Keys
CLAUDE_API_KEY=sk-ant-your-key-here

# CORS — Origins allowed to call the API
# Comma-separated. Add your Azure Static Web Apps URL + localhost for dev.
ALLOWED_ORIGINS=http://localhost:3000,https://lively-dune-00d7f1910.7.azurestaticapps.net
