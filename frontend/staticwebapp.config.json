{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/_next/*", "/favicon.ico", "/*.{css,js,png,jpg,svg,ico,json}"]
  },
  "routes": [
    {
      "route": "/auth/login",
      "rewrite": "/auth/login/index.html"
    },
    {
      "route": "/auth/register",
      "rewrite": "/auth/register/index.html"
    },
    {
      "route": "/dashboard",
      "rewrite": "/dashboard/index.html"
    },
    {
      "route": "/onboarding",
      "rewrite": "/onboarding/index.html"
    }
  ],
  "globalHeaders": {
    "X-Content-Type-Options": "nosniff",
    "X-Frame-Options": "DENY",
    "Referrer-Policy": "strict-origin-when-cross-origin"
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
