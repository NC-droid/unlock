# Copy this to .env.local and fill in your values
# DO NOT commit .env.local to git

# Azure Entra External ID (formerly Azure AD B2C)
# Found in: Azure Portal → Entra External ID → App Registrations → unlock-app
NEXT_PUBLIC_AZURE_CLIENT_ID=your-client-id-here
NEXT_PUBLIC_AZURE_TENANT_ID=your-tenant-id-here
NEXT_PUBLIC_AZURE_TENANT_NAME=your-tenant-name   # e.g. "unlockapp" (without .onmicrosoft.com)

# Backend API
# Local dev: http://localhost:3001
# Production: https://unlock-app-api.azurewebsites.net
NEXT_PUBLIC_API_URL=http://localhost:3001

# OAuth redirect (must match what's registered in Azure)
NEXT_PUBLIC_REDIRECT_URI=http://localhost:3000/auth/callback
